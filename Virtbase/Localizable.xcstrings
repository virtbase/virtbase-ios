    "Virtbase Schlüssel" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Virtbase Key"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clave Virtbase"
          }
        },
        "fr" : {
          "stringUnit" : {
