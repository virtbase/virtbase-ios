    "Alle Anwendungsdaten löschen?" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delete all application data?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Eliminar todos los datos de la aplicación?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprimer toutes les données de l'application ?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usunąć wszystkie dane aplikacji?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除所有应用数据？"
          }
        }
      }
    },
    "Alle Daten auf dem Server werden gelöscht. Dies lässt sich nicht rückgangig machen." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All data on the server will be deleted. You cannot undo this."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los datos del servidor serán eliminados. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les données du serveur seront supprimées. Cette action est irréversible."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystkie dane na serwerze zostaną usunięte. Nie można tego cofnąć."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "服务器上的所有数据将被删除，此操作无法撤销。"
          }
        }
      }
    },
    "Alle Daten Löschen" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delete all data"
          }
        },
        "es" : {
