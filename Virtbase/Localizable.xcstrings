            "value" : "删除所有数据"
          }
        }
      }
    },
    "Alle lokalen Daten werden entfernt, und sie werden sofort abgemeldet. Dies lässt sich nicht rückgangig machen." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All local data will be removed and you will be logged out. This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los datos locales serán eliminados y se cerrará su sesión. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les données locales seront supprimées et vous serez déconnecté. Cette action est irréversible."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystkie lokalne dane zostaną usunięte i zostaniesz wylogowany. Nie można tego cofnąć."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有本地数据将被删除，您将立即退出登录，此操作无法撤销。"
          }
        }
      }
    },
